# Phoenix — minimal runtime container (FROM scratch)
#
# The Go binary is statically compiled (CGO_ENABLED=0) and needs no OS runtime.
# We only add a CA certificate bundle so the binary can verify TLS connections
# to LLM providers.
#
# The deploy script supplies ca-certificates.crt from the server's CA bundle
# (~/scs-containers/ca-certificates.crt) which includes both standard root CAs
# and the corporate NetApp engineering CA.
#
# Build: podman build -f Containerfile.deploy -t phoenix:latest .
# (run from a dir containing phoenix-linux and ca-certificates.crt)

FROM scratch

# TLS trust bundle
COPY ca-certificates.crt /etc/ssl/certs/ca-certificates.crt

# Static binary
COPY phoenix-linux /phoenix

VOLUME /data

ENV PHOENIX_PORT=8090
ENV PHOENIX_DB_PATH=/data/phoenix.db

EXPOSE 8090

ENTRYPOINT ["/phoenix"]
