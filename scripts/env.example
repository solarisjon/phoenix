# Phoenix production environment variables
# Copy to .env and customise before deploying.
# All values are optional — defaults shown in comments.

# TCP port Phoenix listens on inside the container (mapped to host via -p).
PHOENIX_PORT=8090

# SQLite database path inside the container — matches the volume mount.
PHOENIX_DB_PATH=/data/phoenix.db

# Maximum time a single agent task may run (Go duration string).
# Default: 30m
#PHOENIX_TASK_TIMEOUT=30m

# How often the monitor scheduler polls for due tasks.
# Default: 60s
#PHOENIX_SCHEDULER_INTERVAL=60s

# Per-request HTTP handler timeout.
# Default: 60s
#PHOENIX_HTTP_TIMEOUT=60s

# Comma-separated extra CORS origins allowed to call the API.
# Not needed when accessing Phoenix from its own embedded frontend.
#PHOENIX_CORS_ORIGIN=
