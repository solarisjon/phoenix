# Phoenix VPS environment — copy to .env and fill in real values.
PHOENIX_PORT=8090
PHOENIX_DB_PATH=/data/phoenix.db

# Enable the login screen.
PHOENIX_AUTH_ENABLED=true

# Seed users on startup: comma-separated "username:password" pairs.
# Passwords are bcrypt-hashed at startup; update and redeploy to change them.
PHOENIX_SEED_USERS=jon:change_me_password,wife:change_me_password

# Optional: override task/scheduler timeouts.
# PHOENIX_TASK_TIMEOUT=30m
# PHOENIX_SCHEDULER_INTERVAL=60s
# PHOENIX_HTTP_TIMEOUT=60s
