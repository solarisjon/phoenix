# Phoenix server environment — copy to .env and set real values before deploying.
#
# cp scripts/env.server.example .env
# nano .env

# Port the container binds on the host.
PHOENIX_PORT=8090

# Persistent database path (inside the /data volume).
PHOENIX_DB_PATH=/data/phoenix.db

# Enable the login screen.
PHOENIX_AUTH_ENABLED=true

# Seed users on startup: comma-separated "username:password" pairs.
# Passwords are bcrypt-hashed; update here and redeploy to change them.
PHOENIX_SEED_USERS=jon:change_me,wife:change_me

# Optional tuning (uncomment to override defaults).
# PHOENIX_TASK_TIMEOUT=30m
# PHOENIX_SCHEDULER_INTERVAL=60s
# PHOENIX_HTTP_TIMEOUT=60s
